<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+.
    GDPR / COPPA: excludes PII from both cloud backup and device-to-device transfer.
    Docs: https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Child's name — PII, must not reach Google servers -->
        <exclude domain="file" path="datastore/user_prefs.preferences_pb"/>
        <!-- Gamification + challenge = behavioural profile of a minor -->
        <exclude domain="file" path="datastore/gamification_prefs.preferences_pb"/>
        <exclude domain="file" path="datastore/challenge_prefs.preferences_pb"/>
        <!-- Room database (toy list, prices, photo URIs) -->
        <exclude domain="database" path="toy_db"/>
        <exclude domain="database" path="toy_db-shm"/>
        <exclude domain="database" path="toy_db-wal"/>
        <!-- Photo files -->
        <exclude domain="file" path="Pictures"/>
        <exclude domain="file" path="Toy_Images"/>
    </cloud-backup>

    <device-transfer>
        <!-- Same exclusions apply for device-to-device transfers -->
        <exclude domain="file" path="datastore/user_prefs.preferences_pb"/>
        <exclude domain="file" path="datastore/gamification_prefs.preferences_pb"/>
        <exclude domain="file" path="datastore/challenge_prefs.preferences_pb"/>
        <exclude domain="database" path="toy_db"/>
        <exclude domain="database" path="toy_db-shm"/>
        <exclude domain="database" path="toy_db-wal"/>
        <exclude domain="file" path="Pictures"/>
        <exclude domain="file" path="Toy_Images"/>
    </device-transfer>
</data-extraction-rules>
